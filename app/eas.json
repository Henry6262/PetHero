{
  "cli": {
    "version": ">= 19.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_PETHERO_API": "https://pethero-backend-production.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
