# Copy to .env and fill in. All optional — backend runs fully stubbed without them.

# Mistral decision agent (console.mistral.ai). Without it, agent uses a rule-based fallback.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Hugging Face Inference (CLIP individual-pet ID). Without it, vision uses generic cat/dog.
HF_TOKEN=

# Camera source: "auto" (try webcam 0, else placeholder), "none" (placeholder only),
# or a path to an image/video file used as the demo feed.
PETHERO_CAMERA=auto

# Start mode: "demo" (mock dispense / video replay) or "live" (drive the robot).
PETHERO_MODE=demo
